# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Node / frontend build
node_modules/
demo/frontend/dist/

# Env — the operator provides their own (see README "Configuration")
.env
.env.*

# OS / IDE
.DS_Store
.vscode/
.idea/
*.swp

# NOTE: checkpoints/ is intentionally NOT ignored — the sft_v2 LoRA adapter
# ships with the repo via git-LFS (see .gitattributes).

# Saved demo conversations are runtime artifacts: keep the folder, ignore contents.
data/demo-saved-trajectory/*
!data/demo-saved-trajectory/.gitkeep
